{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CGS Advisors",
  "version": "0.1.0",
  "identifier": "com.cgs.advisors.demo",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "url": "/",
        "title": "CGS Advisors",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 720,
        "decorations": true,
        "resizable": true
      },
      {
        "label": "recall",
        "url": "/recall-panel/",
        "title": "Recall",
        "width": 380,
        "height": 560,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "resizable": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "store": {},
    "global-shortcut": {}
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
