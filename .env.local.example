# Anthropic — Claude streaming (architecture.md §4)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI — embedding fallback on free-text Recall queries
# (D4: build-time embed is primary path; runtime OpenAI only when user bypasses autocomplete)
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_EMBED_MODEL=text-embedding-3-small

# Dev flags
NEXT_PUBLIC_PREFLIGHT_TIMEOUT_MS=5000

# Offline demo mode — auto-enabled when either API key above is missing
# or still the REPLACE_ME placeholder. Set explicitly to force the
# offline UI even with real keys present (useful for verifying the gates).
# NEXT_PUBLIC_DEMO_MODE=offline
