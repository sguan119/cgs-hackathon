{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CGS Advisors Offline Recall Cache",
  "description": "Schema for fixtures/offline_cache.json (Phase 2A §3.2). Keyed by exact ScriptedQuery.query string — see plan §5.9 correctness callout on key collision.",
  "type": "object",
  "additionalProperties": false,
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "items": { "$ref": "#/definitions/OfflineCacheEntry" }
    }
  },
  "definitions": {
    "OfflineCacheEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["query", "tagged_stream", "precedent_id"],
      "properties": {
        "query": { "type": "string", "minLength": 1 },
        "tagged_stream": { "type": "string", "minLength": 1 },
        "precedent_id": { "type": "string", "minLength": 1 }
      }
    }
  }
}
