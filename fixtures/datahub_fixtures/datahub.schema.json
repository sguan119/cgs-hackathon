{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CGS Advisors Data Hub Fixture",
  "description": "Schema for fixtures/datahub_fixtures/datahub.json (Phase 4.4). Industry-neutral copy; Acme is the expanded row.",
  "type": "object",
  "additionalProperties": false,
  "required": ["uploads", "crmRows", "acmeFolder"],
  "properties": {
    "uploads": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "size", "rows", "status"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "size": { "type": "string", "minLength": 1 },
          "rows": { "type": "integer", "minimum": 0 },
          "status": { "type": "string", "enum": ["tagged", "tagging", "untagged"] }
        }
      }
    },
    "crmRows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "industry", "size", "region", "serviceLine", "stage"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "industry": { "type": "string", "minLength": 1 },
          "size": { "type": "string", "minLength": 1 },
          "region": { "type": "string", "minLength": 1 },
          "serviceLine": {
            "type": "string",
            "enum": [
              "Strategic Transformation",
              "IT Transformation",
              "Enterprise Innovation",
              "Inertia Removal"
            ]
          },
          "stage": {
            "type": "string",
            "enum": ["Signal", "Retainer", "Pre-RFP", "Renewal", "Active Delivery"]
          },
          "flag": { "type": ["string", "null"], "enum": ["new", null] }
        }
      }
    },
    "acmeFolder": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["icon", "name", "meta"],
        "properties": {
          "icon": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "meta": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
