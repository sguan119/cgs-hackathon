{
  "name": "cgs-advisors-demo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "tauri": "cargo tauri",
    "tauri:dev": "cargo tauri dev",
    "tauri:build": "cargo tauri build",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test:phase-0": "node scripts/test-phase-0.js",
    "test:phase-1": "node scripts/test-phase-1.js",
    "test:phase-2a": "node scripts/test-phase-2a.js",
    "test:phase-2b": "node scripts/test-phase-2b.js",
    "test:phase-2c": "node scripts/test-phase-2c.js",
    "test:phase-2d": "node scripts/test-phase-2d.js",
    "test:phase-3": "node scripts/test-phase-3.js",
    "test:phase-4": "node scripts/test-phase-4.js",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "gen:precedent-embeddings": "tsx scripts/gen-precedent-embeddings.ts",
    "gen:scripted-query-embeddings": "tsx scripts/gen-scripted-query-embeddings.ts",
    "gen:embeddings": "pnpm gen:precedent-embeddings && pnpm gen:scripted-query-embeddings",
    "gen:diagnostic-fixtures": "tsx scripts/gen-diagnostic-fixtures.ts",
    "gen:override-cache": "tsx scripts/gen-override-cache.ts",
    "gen:offline-cache": "tsx scripts/gen-offline-cache.ts",
    "gen:all": "pnpm gen:embeddings && pnpm gen:diagnostic-fixtures && pnpm gen:override-cache && pnpm gen:offline-cache",
    "check:fixture-mtimes": "tsx scripts/check-fixture-mtimes.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-global-shortcut": "^2.0.0",
    "@tauri-apps/plugin-store": "^2.1.0",
    "next": "15.0.3",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "printWidth": 100
  },
  "eslintConfig": {
    "extends": [
      "next/core-web-vitals"
    ],
    "rules": {
      "no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_",
          "varsIgnorePattern": "^_"
        }
      ],
      "@next/next/no-html-link-for-pages": "off",
      "import/order": [
        "warn",
        {
          "groups": [
            "builtin",
            "external",
            "internal",
            "parent",
            "sibling",
            "index"
          ],
          "newlines-between": "never",
          "alphabetize": {
            "order": "asc",
            "caseInsensitive": true
          }
        }
      ]
    },
    "ignorePatterns": [
      "out/",
      ".next/",
      "src-tauri/",
      "cgs-ui-design/",
      "node_modules/"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.1.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "ajv": "^8.18.0",
    "ajv-cli": "^5.0.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.0.3",
    "happy-dom": "^20.9.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
